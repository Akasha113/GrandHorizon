{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "build" } },
    { "src": "admin/package.json", "use": "@vercel/static-build", "config": { "distDir": "build" } }
  ],
  "routes": [
    { "src": "/admin/(.*)", "dest": "admin/$1" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}